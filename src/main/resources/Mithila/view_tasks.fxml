<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" 
            xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Mithila.ViewTasksController"
            style="-fx-background-color: #e0f2f1;">
   <children>
      <Label fx:id="title_lbl" layoutX="210.0" layoutY="30.0" text="My Assigned Tasks" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Label fx:id="nid_lbl" layoutX="50.0" layoutY="85.0" text="Officer NID :" />
      <TextField fx:id="nid_txt" layoutX="150.0" layoutY="81.0" prefWidth="180.0" />
      <Button fx:id="load_btn" layoutX="340.0" layoutY="81.0" onAction="#loadTasks" text="Load Tasks" />
      <Button fx:id="back_btn" layoutX="430.0" layoutY="81.0" onAction="#goBack" text="Back" />
      
      <TableView fx:id="task_tbl" layoutX="50.0" layoutY="130.0" prefHeight="240.0" prefWidth="500.0">
        <columns>
          <TableColumn fx:id="id_col" prefWidth="90.0" text="Task ID" />
          <TableColumn fx:id="desc_col" prefWidth="200.0" text="Description" />
          <TableColumn fx:id="due_col" prefWidth="100.0" text="Deadline" />
          <TableColumn fx:id="stat_col" prefWidth="100.0" text="Status" />
        </columns>
      </TableView>
      
      <Button fx:id="ack_btn" layoutX="50.0" layoutY="385.0" onAction="#acknowledgeTask" text="Acknowledge Task" />
      
      <Label fx:id="msg_lbl" layoutX="50.0" layoutY="430.0" text="" />
   </children>
</AnchorPane>
