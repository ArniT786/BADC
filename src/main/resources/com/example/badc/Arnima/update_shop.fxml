<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Arnima.UpdateShopController">
    <children>
        <VBox spacing="12" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Update Shop Information" />
                <Separator />
                <GridPane hgap="10" vgap="10">
                    <children>
                        <Label text="Dealer NID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtDealerNID" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Shop Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtShopName" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="New Address:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <TextField fx:id="txtAddress" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Phone Number:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="txtPhone" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                </GridPane>
                <Separator />
                <HBox spacing="10">
                    <children>
                        <Button text="Load Current Info" onAction="#loadShopInfo" />
                        <Button text="Update Profile" onAction="#updateProfile" />
                        <Button text="Clear" onAction="#clearForm" />
                        <Button text="Back" onAction="#goBack" />
                    </children>
                </HBox>
                <Separator />
                <Label fx:id="lblMessage" text="" />
            </children>
        </VBox>
    </children>
</AnchorPane>
