<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Arnima.RecordSaleController">
    <children>
        <VBox spacing="12" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Record Seed Sale to Farmer" />
                <Separator />
                <GridPane hgap="10" vgap="10">
                    <children>
                        <Label text="Dealer NID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtDealerNID" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        
                        <Label text="Farmer NID:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtFarmerNID" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        
                        <Label text="Seed Type:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <ComboBox fx:id="cmbSeedType" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        
                        <Label text="Quantity Sold (kg):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <TextField fx:id="txtQuantity" prefWidth="200" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                    </children>
                </GridPane>
                <Separator />
                <HBox spacing="10">
                    <children>
                        <Button text="Confirm Sale" onAction="#confirmSale" />
                        <Button text="Clear" onAction="#clearForm" />
                        <Button text="Back" onAction="#goBack" />
                    </children>
                </HBox>
                <Separator />
                <Label text="Stock Check Result:" />
                <Label fx:id="lblStockStatus" text="" />
                <Label fx:id="lblMessage" text="" />
            </children>
        </VBox>
    </children>
</AnchorPane>
