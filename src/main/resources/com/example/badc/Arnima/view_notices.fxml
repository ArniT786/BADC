<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Arnima.ViewNoticesController">
    <children>
        <VBox spacing="12" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Label text="Notices from BADC" />
                <Separator />
                <TableView fx:id="tblNotices" prefHeight="220.0" prefWidth="550.0">
                    <columns>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="120.0" />
                        <TableColumn fx:id="colTitle" text="Notice Title" prefWidth="280.0" />
                        <TableColumn fx:id="colType" text="Type" prefWidth="120.0" />
                    </columns>
                </TableView>
                <Separator />
                <Label text="Full Notice:" />
                <TextArea fx:id="txtNoticeDetail" prefHeight="100.0" prefWidth="550.0" wrapText="true" />
                <HBox spacing="10">
                    <children>
                        <Button text="View Selected" onAction="#viewSelected" />
                        <Button text="Back" onAction="#goBack" />
                    </children>
                </HBox>
                <Label fx:id="lblMessage" text="" />
            </children>
        </VBox>
    </children>
</AnchorPane>
