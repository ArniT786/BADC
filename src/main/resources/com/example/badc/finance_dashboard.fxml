<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20" prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.badc.FinanceDashboardController">
    <children>
        <Label text="BADC Finance Dashboard" textFill="#1565c0">
            <font><Font name="System Bold" size="28.0" /></font>
        </Label>
        <Label fx:id="welcomeLabel" text="Welcome, Finance Officer!" textFill="#757575">
            <font><Font size="16.0" /></font>
        </Label>
        <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #d32f2f; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;" />
    </children>
</VBox>
