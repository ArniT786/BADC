<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.badc.Meraj.Admin.LoginDashboardController">

    <top>
        <Label text="Pending Requests"
               style="-fx-font-size:18px; -fx-padding:10;" />
    </top>

    <center>
        <TableView fx:id="requestTable">
            <columns>
                <TableColumn fx:id="colId" text="Request ID" prefWidth="120"/>
                <TableColumn fx:id="colUser" text="User" prefWidth="150"/>
                <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10"
              alignment="CENTER"
              style="-fx-padding:10;">
            <Button text="Approve"
                    onAction="#handleApprove"/>
            <Button text="Reject"
                    onAction="#handleReject"/>
        </HBox>
    </bottom>

</BorderPane>
