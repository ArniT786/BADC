<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.badc.Meraj.Admin.LogoutController">

    <!-- ===== TOP TITLE ===== -->
    <top>
        <Label text="Logout"
               style="-fx-font-size:20px; -fx-font-weight:bold;">
            <BorderPane.margin>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </BorderPane.margin>
        </Label>
    </top>

    <!-- ===== CENTER CONTENT ===== -->
    <center>
        <VBox alignment="CENTER" spacing="20">

            <padding>
                <Insets top="30" right="30" bottom="30" left="30"/>
            </padding>

            <!-- Confirmation Message -->
            <Label text="Are you sure you want to logout?"
                   style="-fx-font-size:16px;"/>

            <!-- Workflow Buttons -->
            <HBox alignment="CENTER" spacing="15">

                <!-- Event 1 -->
                <Button text="Logout"
                        fx:id="logoutButton"
                        style="-fx-font-weight:bold; -fx-background-color:#ff6666;"/>

                <Button text="Cancel"
                        fx:id="cancelButton"/>

            </HBox>

        </VBox>
    </center>

    <!-- ===== STATUS AREA ===== -->
    <bottom>
        <VBox spacing="6">

            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>

            <!-- Events Status -->
            <Label text="Session Status:"
                   style="-fx-font-weight:bold;"/>

            <!-- Event 7 & 8 -->
            <Label fx:id="statusLabel"
                   text="Waiting for user action..."
                   style="-fx-text-fill:green;"/>

        </VBox>
    </bottom>

</BorderPane>
