<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="720.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.badc.Meraj.FinanceOfficerController">

    <children>


        <Label layoutX="160.0" layoutY="30.0"
               text="Finance Officer Dashboard (BADC)">
            <font>
                <Font size="22.0"/>
            </font>
        </Label>


        <Button layoutX="230.0" layoutY="100.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Login Finance Dashboard"
                onAction="#handleFinanceDashboard"/>


        <Button layoutX="230.0" layoutY="160.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Payments"
                onAction="#handleManagePayments"/>


        <Button layoutX="230.0" layoutY="220.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Subsidy"
                onAction="#handleSubsidyFund"/>


        <Button layoutX="230.0" layoutY="280.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Budget"
                onAction="#handleBudgetManagement"/>

    </children>

</AnchorPane>
