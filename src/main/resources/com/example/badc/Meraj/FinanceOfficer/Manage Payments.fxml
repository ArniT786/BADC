<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.badc.Meraj.FinanceOfficer.PaymentController"
            prefHeight="480.0" prefWidth="750.0">

    <children>


        <Label text="Manage Payments"
               layoutX="280" layoutY="15"
               style="-fx-font-size:20px; -fx-font-weight:bold;" />


        <TableView fx:id="paymentTable"
                   layoutX="40"
                   layoutY="60"
                   prefHeight="260"
                   prefWidth="660">

            <columns>
                <TableColumn fx:id="colPaymentId"
                             text="Payment ID"
                             prefWidth="120"/>

                <TableColumn fx:id="colUser"
                             text="User"
                             prefWidth="160"/>

                <TableColumn fx:id="colAmount"
                             text="Amount"
                             prefWidth="150"/>

                <TableColumn fx:id="colMethod"
                             text="Method"
                             prefWidth="120"/>

                <TableColumn fx:id="colStatus"
                             text="Status"
                             prefWidth="110"/>
            </columns>

        </TableView>


        <Label text="Details:"
               layoutX="50"
               layoutY="340"/>

        <TextArea fx:id="txtDetails"
                  layoutX="110"
                  layoutY="330"
                  prefHeight="60"
                  prefWidth="400"/>


        <Button text="Approve Payment"
                layoutX="200"
                layoutY="410"
                prefWidth="140"
                onAction="#handleApprovePayment"/>

        <Button text="Refresh"
                layoutX="380"
                layoutY="410"
                prefWidth="120"
                onAction="#handleRefresh"/>

    </children>

</AnchorPane>