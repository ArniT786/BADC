<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="520.0" prefWidth="720.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.badc.Meraj.FinanceOfficer.FinanceOfficerController">

    <children>

        <!-- TITLE -->
        <Label layoutX="140.0" layoutY="25.0"
               text="Finance Officer Dashboard (BADC)">
            <font>
                <Font size="22.0"/>
            </font>
        </Label>

        <!-- BUTTON 1 -->
        <Button layoutX="230.0" layoutY="80.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Login &amp; View Finance Dashboard"
                onAction="#handleFinanceDashboard"/>

        <!-- BUTTON 2 -->
        <Button layoutX="230.0" layoutY="130.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Manage Payments"
                onAction="#handleManagePayments"/>

        <!-- BUTTON 3 -->
        <Button layoutX="230.0" layoutY="180.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Subsidy Fund Disbursement"
                onAction="#handleSubsidyFund"/>

        <!-- BUTTON 4 -->
        <Button layoutX="230.0" layoutY="230.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Budget Management"
                onAction="#handleBudgetManagement"/>

        <!-- BUTTON 5 -->
        <Button layoutX="230.0" layoutY="280.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Financial Report Generation"
                onAction="#handleFinancialReport"/>

        <!-- BUTTON 6 -->
        <Button layoutX="230.0" layoutY="330.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Audit &amp; Transaction Review"
                onAction="#handleAuditReview"/>

        <!-- BUTTON 7 -->
        <Button layoutX="230.0" layoutY="380.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Expense Tracking"
                onAction="#handleExpenseTracking"/>

        <!-- BUTTON 8 -->
        <Button layoutX="230.0" layoutY="430.0"
                prefWidth="270.0" prefHeight="40.0"
                text="Logout"
                onAction="#handleLogout"/>

    </children>

</AnchorPane>
