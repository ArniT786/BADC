<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="700.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.badc.Meraj.AdminBADCController">

    <children>


        <Label layoutX="180.0" layoutY="30.0"
               text="Admin Dashboard (BADC Officer)">
            <font>
                <Font size="22.0"/>
            </font>
        </Label>


        <Button layoutX="220.0" layoutY="100.0"
                prefWidth="260.0" prefHeight="40.0"
                text="Login Dashboard"
                onAction="#handleLoginDashboard"/>


        <Button layoutX="220.0" layoutY="160.0"
                prefWidth="260.0" prefHeight="40.0"
                text="User Management"
                onAction="#handleManageUsers"/>


        <Button layoutX="220.0" layoutY="220.0"
                prefWidth="260.0" prefHeight="40.0"
                text="pending Requests"
                onAction="#handleApproveRequests"/>


        <Button layoutX="220.0" layoutY="280.0"
                prefWidth="260.0" prefHeight="40.0"
                text="Inventory "
                onAction="#handleInventoryOverview"/>

    </children>

</AnchorPane>
