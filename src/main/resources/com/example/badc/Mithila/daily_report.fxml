<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" 
            xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Mithila.DailyReportController"
            style="-fx-background-color: #f1f8e9;">
   <children>
      <Label fx:id="title_lbl" layoutX="230.0" layoutY="30.0" text="Daily Work Report" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Label fx:id="nid_lbl" layoutX="100.0" layoutY="85.0" text="Officer NID :" />
      <TextField fx:id="nid_txt" layoutX="220.0" layoutY="81.0" prefWidth="250.0" />
      
      <Label fx:id="date_lbl" layoutX="100.0" layoutY="130.0" text="Report Date :" />
      <DatePicker fx:id="date_dp" layoutX="220.0" layoutY="126.0" prefWidth="250.0" />
      
      <Label fx:id="summ_lbl" layoutX="100.0" layoutY="175.0" text="Activity Summary :" />
      <TextField fx:id="summ_txt" layoutX="100.0" layoutY="205.0" prefWidth="400.0" prefHeight="100.0" />
      
      <Button fx:id="sub_btn" layoutX="100.0" layoutY="330.0" onAction="#submitReport" prefWidth="120" text="Submit Report" />
      <Button fx:id="clr_btn" layoutX="230.0" layoutY="330.0" onAction="#clearForm" prefWidth="80" text="Clear" />
      <Button fx:id="back_btn" layoutX="320.0" layoutY="330.0" onAction="#goBack" prefWidth="80" text="Cancel" />
      
      <Label fx:id="msg_lbl" layoutX="100.0" layoutY="390.0" text="" />
   </children>
</AnchorPane>
