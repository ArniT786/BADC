<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.badc.Mithila.VerifyActivitiesController">
   <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
      </padding>
      <Label text="Verify Field Officer Activities" />
      <Separator />
      <HBox spacing="10.0">
         <Label prefWidth="130.0" text="Officer Name :" />
         <ComboBox fx:id="officerDrop" prefWidth="200.0" />
      </HBox>
      <HBox>
         <Label prefWidth="130.0" text="Officer NID :" />
         <TextField fx:id="officerNid" prefWidth="200.0" />
      </HBox>
      <HBox spacing="8.0">
         <Button onAction="#loadLogs" text="Load Logs" />
         <Button onAction="#goBack" text="Go Back" />
      </HBox>
      <Separator />
      <TableView fx:id="logTable" prefHeight="220.0" prefWidth="540.0">
        <TableColumn fx:id="colDate" prefWidth="110.0" text="Date" />
        <TableColumn fx:id="colSummary" prefWidth="260.0" text="Activity Summary" />
        <TableColumn fx:id="colStat" prefWidth="120.0" text="Status" />
      </TableView>
      <Separator />
      <HBox spacing="10.0">
         <Button onAction="#approveLog" text="Approve" />
         <Button onAction="#rejectLog" text="Needs Correction" />
      </HBox>
      <Label fx:id="msgLabel" text="" />
   </VBox>
</AnchorPane>

