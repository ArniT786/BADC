<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" 
            xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Mithila.CropYieldController"
            style="-fx-background-color: #fce4ec;">
   <children>
      <Label fx:id="title_lbl" layoutX="230.0" layoutY="30.0" text="Crop Yield Entry" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Label fx:id="nid_lbl" layoutX="100.0" layoutY="85.0" text="Farmer NID :" />
      <TextField fx:id="nid_txt" layoutX="220.0" layoutY="81.0" prefWidth="250.0" />
      
      <Label fx:id="crop_lbl" layoutX="100.0" layoutY="130.0" text="Crop Type :" />
      <ComboBox fx:id="crop_cb" layoutX="220.0" layoutY="126.0" prefWidth="250.0" />
      
      <Label fx:id="seas_lbl" layoutX="100.0" layoutY="175.0" text="Season :" />
      <ComboBox fx:id="seas_cb" layoutX="220.0" layoutY="171.0" prefWidth="250.0" />
      
      <Label fx:id="harv_lbl" layoutX="100.0" layoutY="220.0" text="Harvest (kg) :" />
      <TextField fx:id="harv_txt" layoutX="220.0" layoutY="216.0" prefWidth="250.0" />
      
      <Button fx:id="veri_btn" layoutX="100.0" layoutY="280.0" onAction="#verifyFarmer" prefWidth="80" text="Verify" />
      <Button fx:id="save_btn" layoutX="190.0" layoutY="280.0" onAction="#saveYieldData" prefWidth="80" text="Save" />
      <Button fx:id="clr_btn" layoutX="280.0" layoutY="280.0" onAction="#clearForm" prefWidth="80" text="Clear" />
      <Button fx:id="back_btn" layoutX="370.0" layoutY="280.0" onAction="#goBack" prefWidth="80" text="Back" />
      
      <Label fx:id="veri_lbl" layoutX="100.0" layoutY="330.0" text="" />
      <Label fx:id="msg_lbl" layoutX="100.0" layoutY="360.0" text="" />
   </children>
</AnchorPane>
