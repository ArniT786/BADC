<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" 
            xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Mithila.MonitorIssuesController"
            style="-fx-background-color: #f1f8e9;">
   <children>
      <Label fx:id="title_lbl" layoutX="190.0" layoutY="30.0" text="Agricultural Issue Monitor" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Button fx:id="load_btn" layoutX="50.0" layoutY="80.0" onAction="#loadIssues" text="Load All Issues" />
      <Button fx:id="back_btn" layoutX="170.0" layoutY="80.0" onAction="#goBack" text="Back" />
      
      <TableView fx:id="issueTable" layoutX="50.0" layoutY="125.0" prefHeight="230.0" prefWidth="500.0">
        <columns>
          <TableColumn fx:id="colId" prefWidth="90.0" text="Issue ID" />
          <TableColumn fx:id="colLocation" prefWidth="120.0" text="Location" />
          <TableColumn fx:id="colDesc" prefWidth="180.0" text="Description" />
          <TableColumn fx:id="colPriority" prefWidth="100.0" text="Priority" />
        </columns>
      </TableView>
      
      <Label fx:id="det_lbl" layoutX="50.0" layoutY="370.0" text="Issue Detail :" />
      <TextArea fx:id="detailArea" layoutX="50.0" layoutY="395.0" prefWidth="500.0" prefHeight="60.0" />
      
      <Label fx:id="msgLabel" layoutX="50.0" layoutY="465.0" text="" />
   </children>
</AnchorPane>
