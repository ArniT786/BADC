<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.badc.Mithila.MonitorIssuesController">
   <VBox spacing="8.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <Label text="Agricultural Issue Monitor" />
      <Separator />
      <HBox spacing="10.0">
         <Button onAction="#loadIssues" text="Load All Issues" />
         <Button onAction="#goBack" text="Back" />
      </HBox>
      <Separator />
      <TableView fx:id="issueTable" prefHeight="240.0" prefWidth="540.0">
        <TableColumn fx:id="colId" prefWidth="90.0" text="Issue ID" />
        <TableColumn fx:id="colLocation" prefWidth="140.0" text="Location" />
        <TableColumn fx:id="colDesc" prefWidth="180.0" text="Description" />
        <TableColumn fx:id="colPriority" prefWidth="100.0" text="Priority" />
      </TableView>
      <Separator />
      <Label text="Issue Detail :" />
      <TextArea fx:id="detailArea" prefHeight="80.0" prefWidth="530.0" wrapText="true" />
      <Label fx:id="msgLabel" text="" />
   </VBox>
</AnchorPane>

