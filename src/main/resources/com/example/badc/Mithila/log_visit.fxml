<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" 
            xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Mithila.LogVisitController"
            style="-fx-background-color: #fffde7;">
   <children>
      <Label fx:id="title_lbl" layoutX="230.0" layoutY="30.0" text="Farmer Visit Log" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Label fx:id="nid_lbl" layoutX="100.0" layoutY="85.0" text="Farmer NID :" />
      <TextField fx:id="nid_txt" layoutX="220.0" layoutY="81.0" prefWidth="250.0" />
      
      <Label fx:id="date_lbl" layoutX="100.0" layoutY="130.0" text="Visit Date :" />
      <DatePicker fx:id="date_dp" layoutX="220.0" layoutY="126.0" prefWidth="250.0" />
      
      <Label fx:id="advice_lbl" layoutX="100.0" layoutY="175.0" text="Advice Given :" />
      <TextField fx:id="advice_txt" layoutX="220.0" layoutY="171.0" prefWidth="250.0" />
      
      <Label fx:id="notes_lbl" layoutX="100.0" layoutY="220.0" text="Notes :" />
      <TextField fx:id="notes_txt" layoutX="220.0" layoutY="216.0" prefWidth="250.0" />
      
      <Button fx:id="save_btn" layoutX="220.0" layoutY="280.0" onAction="#saveVisitLog" prefWidth="80.0" text="Save Log" />
      <Button fx:id="clr_btn" layoutX="310.0" layoutY="280.0" onAction="#clearForm" prefWidth="80.0" text="Clear" />
      <Button fx:id="back_btn" layoutX="400.0" layoutY="280.0" onAction="#goBack" prefWidth="80.0" text="Go Back" />
      
      <Label fx:id="msg_lbl" layoutX="100.0" layoutY="340.0" text="" />
   </children>
</AnchorPane>
