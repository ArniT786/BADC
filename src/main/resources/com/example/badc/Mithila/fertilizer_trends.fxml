<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.badc.Mithila.FertilizerTrendsController">
   <VBox spacing="8.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <Label text="Fertilizer Usage Trends" />
      <Separator />
      <HBox spacing="10.0">
         <Label prefWidth="130.0" text="Fertilizer Type :" />
         <ComboBox fx:id="fertDrop" prefWidth="200.0" />
      </HBox>
      <HBox>
         <Label prefWidth="130.0" text="From Date :" />
         <TextField fx:id="fromDate" prefWidth="180.0" />
      </HBox>
      <HBox spacing="10.0">
         <Label prefWidth="130.0" text="To Date :" />
         <TextField fx:id="toDate" prefWidth="180.0" />
      </HBox>
      <Separator />
      <HBox spacing="8.0">
         <Button onAction="#analyseUsage" text="Analyse" />
         <Button onAction="#clearForm" text="Clear" />
         <Button onAction="#goBack" text="Back" />
      </HBox>
      <Separator />
      <TableView fx:id="trendTable" prefHeight="210.0" prefWidth="540.0">
        <TableColumn fx:id="colDate" prefWidth="120.0" text="Date" />
        <TableColumn fx:id="colFert" prefWidth="130.0" text="Fertilizer" />
        <TableColumn fx:id="colUsed" prefWidth="120.0" text="Used (kg)" />
        <TableColumn fx:id="colLeft" prefWidth="150.0" text="Remaining (kg)" />
      </TableView>
      <Label fx:id="msgLabel" text="" />
   </VBox>
</AnchorPane>

