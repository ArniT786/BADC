<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.badc.Mithila.FarmerSummaryController">
   <VBox spacing="8.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <padding>
         <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
      </padding>
      <Label text="Farmer Summary Report" />
      <Separator />
      <HBox spacing="10.0">
         <Label prefWidth="120.0" text="Region :" />
         <ComboBox fx:id="regionBox" prefWidth="200.0" />
      </HBox>
      <HBox>
         <Label prefWidth="120.0" text="Officer NID :" />
         <TextField fx:id="officerNid" prefWidth="200.0" />
      </HBox>
      <Separator />
      <HBox spacing="8.0">
         <Button onAction="#generateReport" text="Generate Report" />
         <Button onAction="#goBack" text="Go Back" />
      </HBox>
      <Separator />
      <TableView fx:id="farmerTable" prefHeight="230.0" prefWidth="540.0">
        <TableColumn fx:id="colNid" prefWidth="130.0" text="Farmer NID" />
        <TableColumn fx:id="colName" prefWidth="150.0" text="Name" />
        <TableColumn fx:id="colRegion" prefWidth="120.0" text="Region" />
        <TableColumn fx:id="colLand" prefWidth="120.0" text="Land (acres)" />
      </TableView>
      <Label fx:id="msgLabel" text="" />
   </VBox>
</AnchorPane>

