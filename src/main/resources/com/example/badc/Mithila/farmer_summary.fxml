<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" 
            xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Mithila.FarmerSummaryController"
            style="-fx-background-color: #fce4ec;">
   <children>
      <Label fx:id="title_lbl" layoutX="190.0" layoutY="30.0" text="Farmer Summary Report" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Label fx:id="reg_lbl" layoutX="50.0" layoutY="85.0" text="Region :" />
      <ComboBox fx:id="reg_cb" layoutX="150.0" layoutY="81.0" prefWidth="200.0" />
      
      <Label fx:id="nid_lbl" layoutX="50.0" layoutY="130.0" text="Officer NID :" />
      <TextField fx:id="nid_txt" layoutX="150.0" layoutY="126.0" prefWidth="200.0" />
      
      <Button fx:id="gen_btn" layoutX="150.0" layoutY="175.0" onAction="#generateReport" text="Generate Report" />
      <Button fx:id="back_btn" layoutX="280.0" layoutY="175.0" onAction="#goBack" text="Go Back" />
      
      <TableView fx:id="farmer_tbl" layoutX="50.0" layoutY="220.0" prefHeight="230.0" prefWidth="500.0">
        <columns>
          <TableColumn fx:id="nid_col" prefWidth="120.0" text="Farmer NID" />
          <TableColumn fx:id="name_col" prefWidth="150.0" text="Name" />
          <TableColumn fx:id="reg_col" prefWidth="120.0" text="Region" />
          <TableColumn fx:id="land_col" prefWidth="100.0" text="Land (acres)" />
        </columns>
      </TableView>
      
      <Label fx:id="msg_lbl" layoutX="50.0" layoutY="460.0" text="" />
   </children>
</AnchorPane>
