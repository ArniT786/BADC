<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>

<AnchorPane prefHeight="500.0" prefWidth="600.0" 
            xmlns="http://javafx.com/javafx" 
            xmlns:fx="http://javafx.com/fxml" 
            fx:controller="com.example.badc.Mithila.DistributeInputController"
            style="-fx-background-color: #e1f5fe;">
   <children>
      <Label fx:id="title_lbl" layoutX="190.0" layoutY="30.0" text="Seed / Fertilizer Distribution" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
      
      <Label fx:id="nid_lbl" layoutX="100.0" layoutY="85.0" text="Farmer NID :" />
      <TextField fx:id="nid_txt" layoutX="240.0" layoutY="81.0" prefWidth="220.0" />
      
      <Label fx:id="type_lbl" layoutX="100.0" layoutY="130.0" text="Item Type :" />
      <ComboBox fx:id="type_cb" layoutX="240.0" layoutY="126.0" prefWidth="220.0" />
      
      <Label fx:id="name_lbl" layoutX="100.0" layoutY="175.0" text="Item Name :" />
      <ComboBox fx:id="name_cb" layoutX="240.0" layoutY="171.0" prefWidth="220.0" />
      
      <Label fx:id="qty_lbl" layoutX="100.0" layoutY="220.0" text="Qty (kg) :" />
      <TextField fx:id="qty_txt" layoutX="240.0" layoutY="216.0" prefWidth="220.0" />
      
      <Button fx:id="check_btn" layoutX="100.0" layoutY="280.0" onAction="#checkEligibility" text="Check Eligibility" />
      <Button fx:id="conf_btn" layoutX="220.0" layoutY="280.0" onAction="#confirmDistribution" text="Confirm" />
      <Button fx:id="clr_btn" layoutX="320.0" layoutY="280.0" onAction="#clearForm" text="Clear" />
      <Button fx:id="back_btn" layoutX="400.0" layoutY="280.0" onAction="#goBack" text="Cancel" />
      
      <Label fx:id="elig_lbl" layoutX="100.0" layoutY="330.0" text="" />
      <Label fx:id="msg_lbl" layoutX="100.0" layoutY="360.0" text="" />
   </children>
</AnchorPane>
